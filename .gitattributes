# Default: auto-normalize all text files to LF in repo, native in working directory
* text=auto eol=lf

# Shell scripts must be LF
*.sh text eol=lf

# PowerShell scripts keep CRLF (Windows native)
*.ps1 text eol=crlf

# Windows batch files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (never convert)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.jar binary
*.class binary
