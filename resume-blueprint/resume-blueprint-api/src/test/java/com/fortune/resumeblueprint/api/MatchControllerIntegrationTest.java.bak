package com.fortune.resumeblueprint.api;

import com.fortune.resumeblueprint.api.dto.MatchRequest;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.http.MediaType;
import org.springframework.test.web.servlet.MockMvc;

import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.post;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

/**
 * Integration test for MatchController
 * 
 * Note: These tests require a running database. Match results may be empty if no success profiles exist.
 */
@SpringBootTest
@AutoConfigureMockMvc
class MatchControllerIntegrationTest {

    @Autowired
    private MockMvc mockMvc;

    @Autowired
    private ObjectMapper objectMapper;

    @Test
    void testMatch_ValidationFailure_MissingResumeDocumentId() throws Exception {
        MatchRequest request = new MatchRequest(
                null,  // Missing resumeDocumentId
                "both",
                null,
                null
        );

        mockMvc.perform(post("/api/match")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isBadRequest());
    }

    @Test
    void testMatch_WithValidRequest_EmptyMatchesAcceptable() throws Exception {
        // This test assumes documentId 1 exists
        // If not, it may fail, but that's acceptable for integration test
        // In a real scenario, we'd create a resume first
        
        MatchRequest request = new MatchRequest(
                1L,
                "both",
                null,
                null
        );

        mockMvc.perform(post("/api/match")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isOk())
                .andExpect(content().contentType(MediaType.APPLICATION_JSON))
                .andExpect(jsonPath("$.matchRunId").exists())
                .andExpect(jsonPath("$.matches").exists())
                .andExpect(jsonPath("$.matches").isArray());
        // Note: matches array can be empty if no success profiles exist - that's acceptable
    }

    @Test
    void testMatch_WithFilters() throws Exception {
        MatchRequest request = new MatchRequest(
                1L,
                "internal",
                "Java Backend Engineer",
                "mid"
        );

        mockMvc.perform(post("/api/match")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isOk())
                .andExpect(content().contentType(MediaType.APPLICATION_JSON))
                .andExpect(jsonPath("$.matchRunId").exists())
                .andExpect(jsonPath("$.matches").isArray());
    }
}
