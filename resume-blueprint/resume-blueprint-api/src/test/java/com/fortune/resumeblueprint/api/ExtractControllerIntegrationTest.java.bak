package com.fortune.resumeblueprint.api;

import com.fortune.resumeblueprint.api.dto.ExtractRequest;
import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.http.MediaType;
import org.springframework.test.web.servlet.MockMvc;

import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.post;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

/**
 * Integration test for ExtractController
 * 
 * Note: These tests require a running database and may require extract-service (Python) to be available.
 */
@SpringBootTest
@AutoConfigureMockMvc
class ExtractControllerIntegrationTest {

    @Autowired
    private MockMvc mockMvc;

    @Autowired
    private ObjectMapper objectMapper;

    private static final String TEST_TEXT = "Java developer with Spring Boot experience.";

    @Test
    void testHealthCheck_Success() throws Exception {
        mockMvc.perform(get("/api/extract/health"))
                .andExpect(status().isOk())
                .andExpect(content().contentType(MediaType.APPLICATION_JSON))
                .andExpect(jsonPath("$.runId").exists())
                .andExpect(jsonPath("$.message").exists())
                .andExpect(jsonPath("$.message").isString());
    }

    @Test
    void testExtract_ValidationFailure_MissingDocumentId() throws Exception {
        ExtractRequest request = new ExtractRequest(
                null,  // Missing documentId
                TEST_TEXT,
                "RESUME"
        );

        mockMvc.perform(post("/api/extract")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isBadRequest());
    }

    @Test
    void testExtract_ValidationFailure_MissingText() throws Exception {
        ExtractRequest request = new ExtractRequest(
                1L,
                "",  // Empty text
                "RESUME"
        );

        mockMvc.perform(post("/api/extract")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().isBadRequest());
    }

    @Test
    void testExtract_WithValidRequest() throws Exception {
        // Note: This test may fail if extract-service is not available
        // That's acceptable - the test verifies the API contract, not the external service
        
        ExtractRequest request = new ExtractRequest(
                1L,  // Assumes documentId 1 exists (may need to create it first in a real scenario)
                TEST_TEXT,
                "RESUME"
        );

        // This will likely return 200 even if extract-service is unavailable
        // The actual behavior depends on implementation
        mockMvc.perform(post("/api/extract")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(request)))
                .andExpect(status().is2xxSuccessful())  // 200 or 503 depending on service availability
                .andExpect(content().contentType(MediaType.APPLICATION_JSON))
                .andExpect(jsonPath("$.runId").exists())
                .andExpect(jsonPath("$.message").exists());
    }
}
